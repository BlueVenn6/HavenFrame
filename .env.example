# HavenFrame local development settings.
# Copy to .env.local or backend/.env.local. Never commit real credentials.

OPENAI_API_KEY=
GEMINI_API_KEY=
ZHIPU_API_KEY=
ZAI_API_KEY=

OPENAI_RELAY_BASE_URL=
OPENAI_RELAY_API_KEY=
OPENAI_RELAY_MODEL=gpt-image-2
GEMINI_RELAY_BASE_URL=
GEMINI_RELAY_API_KEY=

CUSTOM_REST_BASE_URL=
CUSTOM_REST_API_KEY=

# Real paid image calls are opt-in and must never run in normal automated tests.
LIVE_COSTLY_MODEL_TESTS=0
MODEL_CONNECTIVITY_TIMEOUT_SEC=10

# desktop_client exposes only the packaged desktop client capabilities.
QIGOU_API_PROFILE=desktop_client
QIGOU_ALLOWED_HOSTS=
QIGOU_ALLOWED_ORIGINS=
