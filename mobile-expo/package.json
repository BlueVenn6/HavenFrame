{
  "name": "mobile-expo",
  "version": "1.1.3",
  "license": "AGPL-3.0-or-later",
  "main": "index.ts",
  "dependencies": {
    "@react-native-picker/picker": "2.11.4",
    "expo": "~56.0.16",
    "expo-file-system": "~57.0.1",
    "expo-image-manipulator": "~56.0.22",
    "expo-image-picker": "~56.0.21",
    "expo-localization": "~56.0.6",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:platform-parity": "node scripts/test-platform-parity.mjs",
    "test:i18n": "node scripts/test-i18n.mjs",
    "test:report": "node scripts/test-mobile-report.mjs",
    "test:runtime-selection": "node scripts/test-runtime-selection.mjs",
    "test:connectivity": "node scripts/test-connectivity.mjs",
    "test:provider-errors": "node scripts/test-provider-errors.mjs",
    "android:prepare:local": "node scripts/build-android-local.mjs --prepare-only",
    "build:android": "node scripts/build-android-local.mjs",
    "build:android:internal": "node scripts/build-android-local.mjs --internal-release",
    "bundle:android:local": "expo export --platform android --output-dir dist/android",
    "bundle:ios:local": "expo export --platform ios --output-dir dist/ios"
  },
  "private": true
}
